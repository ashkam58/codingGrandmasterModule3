<!DOCTYPE html>
<html lang="en">
<head>
  <title>My Carousel Gallery</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
  <style>
    body {
      background-color: #343a40;
      color: white;
    }
    /* Force images to fit nicely inside the carousel */
    .carousel-inner img {
      width: 100%;
      height: 500px;
      object-fit: cover;
      border-radius: 10px;
    }
  </style>
</head>
<body>

  <div class="container mt-5">
    <h2 class="text-center mb-4 text-warning">My Photography Portfolio</h2>
    
    <div id="myGallery" class="carousel slide shadow" data-ride="carousel">
      
      <ul class="carousel-indicators">
        <li data-target="#myGallery" data-slide-to="0" class="active"></li>
        <li data-target="#myGallery" data-slide-to="1"></li>
        <li data-target="#myGallery" data-slide-to="2"></li>
      </ul>
      
      <div class="carousel-inner">
        <div class="carousel-item active">
          <img src="https://images.unsplash.com/photo-1506748686214-e9df14d4d9d0" alt="Mountain Lake">
          <div class="carousel-caption">
            <h3 class="text-white bg-dark d-inline-block px-2 rounded">Mountain Lake</h3>
            <p class="font-weight-bold">A beautiful scenic view of nature.</p>
          </div>
        </div>
        
        <div class="carousel-item">
          <img src="https://images.unsplash.com/photo-1519681393784-d120267933ba" alt="Snowy Peaks">
          <div class="carousel-caption">
            <h3 class="text-white bg-dark d-inline-block px-2 rounded">Snowy Peaks</h3>
            <p class="font-weight-bold">High up in the winter mountains.</p>
          </div>
        </div>
        
        <div class="carousel-item">
          <img src="https://images.unsplash.com/photo-1470071459604-3b5ec3a7fe05" alt="Misty Forest">
          <div class="carousel-caption">
            <h3 class="text-white bg-dark d-inline-block px-2 rounded">Misty Forest</h3>
            <p class="font-weight-bold">A quiet morning walk in the woods.</p>
          </div>
        </div>
      </div>
      
      <a class="carousel-control-prev" href="#myGallery" data-slide="prev">
        <span class="carousel-control-prev-icon"></span>
      </a>
      <a class="carousel-control-next" href="#myGallery" data-slide="next">
        <span class="carousel-control-next-icon"></span>
      </a>
    </div>
    </div>

  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.7/umd/popper.min.js"></script>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>
</body>
</html>
