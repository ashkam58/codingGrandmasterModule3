<!DOCTYPE html>
<html lang="en">
<head>
  <title>Travel Destinations</title>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <link rel="stylesheet" href="https://maxcdn.bootstrapcdn.com/bootstrap/4.3.1/css/bootstrap.min.css">
  <style>
    body {
      background-color: #e9ecef;
      font-family: Arial, sans-serif;
    }
    .page-header {
      background-color: #17a2b8;
      color: white;
      padding: 20px;
      border-radius: 8px;
      margin-bottom: 30px;
    }
  </style>
</head>
<body>

  <div class="container mt-4">
    <div class="text-center page-header shadow">
      <h1 class="display-4">World Travel Hub</h1>
      <p>Explore beautiful destinations around the globe!</p>
    </div>
    
    <div class="text-center mb-4">
      <div class="spinner-grow text-success" role="status">
        <span class="sr-only">Loading...</span>
      </div>
      <div class="spinner-grow text-danger" role="status">
        <span class="sr-only">Loading...</span>
      </div>
      <div class="spinner-grow text-warning" role="status">
        <span class="sr-only">Loading...</span>
      </div>
      <p class="text-muted mt-2">Fetching special flight offers...</p>
    </div>

    <div class="row">
      <div class="col-12 col-md-4">
        <div class="card mb-4 shadow">
          <div class="card-header bg-danger text-white text-center">
            Tokyo, Japan
          </div>
          <div class="card-body">
            <h5 class="card-title">City of Lights</h5>
            <p class="card-text">Experience the bustling city streets, ancient temples, and amazing food.</p>
            <button class="btn btn-outline-danger btn-block">Book Flight</button>
          </div>
        </div>
      </div>
      
      <div class="col-12 col-md-4">
        <div class="card mb-4 shadow">
          <div class="card-header bg-info text-white text-center">
            Paris, France
          </div>
          <div class="card-body">
            <h5 class="card-title">City of Love</h5>
            <p class="card-text">Visit the Eiffel Tower, beautiful museums, and enjoy world-class bakeries.</p>
            <button class="btn btn-outline-info btn-block">Book Flight</button>
          </div>
        </div>
      </div>
      
      <div class="col-12 col-md-4">
        <div class="card mb-4 shadow">
          <div class="card-header bg-success text-white text-center">
            Sydney, Australia
          </div>
          <div class="card-body">
            <h5 class="card-title">Harbour City</h5>
            <p class="card-text">Relax on sunny beaches and explore the famous Sydney Opera House.</p>
            <button class="btn btn-outline-success btn-block">Book Flight</button>
          </div>
        </div>
      </div>
    </div>

    <ul class="pagination justify-content-center mt-3">
      <li class="page-item"><a class="page-link text-info" href="#">&laquo; Back</a></li>
      <li class="page-item active"><a class="page-link bg-info border-info" href="#">Page 1</a></li>
      <li class="page-item"><a class="page-link text-info" href="#">Page 2</a></li>
      <li class="page-item"><a class="page-link text-info" href="#">Next &raquo;</a></li>
    </ul>
  </div>

  <script src="https://ajax.googleapis.com/ajax/libs/jquery/3.4.1/jquery.min.js"></script>
  <script src="https://cdnjs.cloudflare.com/ajax/libs/popper.js/1.14.7/umd/popper.min.js"></script>
  <script src="https://maxcdn.bootstrapcdn.com/bootstrap/4.3.1/js/bootstrap.min.js"></script>
</body>
</html>
